# Copy this file to `.env` or `.env.local` and fill in real values.
# Do NOT commit your `.env` or `.env.local` - they are ignored by .gitignore.

# Database
# Either paste Render's External URL here (postgres://user:pass@host:5432/dbname)
# or use the JDBC form that the app reads directly (jdbc:postgresql://host:5432/dbname)
DATABASE_URL=postgresql://smartparking:NiayPSCfeWxZuTTxXntGTSZ8e5Y9KI7I@dpg-d832rtt7vvec73eisei0-a.ohio-postgres.render.com/smartparking_lulf
# If you prefer the explicit JDBC + creds (recommended for Render Web Service env vars),
# set these instead of DATABASE_URL (the app reads DB_URL/DB_USERNAME/DB_PASSWORD):
DB_URL=jdbc:postgresql://HOST:5432/smartparking
DB_USERNAME=smartparking
DB_PASSWORD=replace-with-secure-password

# JWT
JWT_SECRET=replace-with-a-secure-random-32-or-64-char-string
JWT_EXPIRATION=86400000

# Africa's Talking
AT_API_KEY=your-sandbox-key
AT_USERNAME=sandbox
AT_SENDER_ID=SmartPark
AT_ENV=sandbox

# Flutterwave (payments)
FLW_SECRET_KEY=replace-with-flutterwave-secret

# Local dev overrides
PORT=8080
ALLOWED_ORIGINS=https://smart-parking-orpin.vercel.app
