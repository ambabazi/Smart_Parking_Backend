# .env — Smart Parking Configuration
# NEVER commit .env with real values to GitHub — use .env.local for local development

PORT=8080

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/smart_parking
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Configuration — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRATION=86400000

# Africa's Talking SMS/USSD
AT_USERNAME=sandbox
AT_API_KEY=your-sandbox-key-from-account.africastalking.com
AT_SENDER_ID=SmartPark
AT_ENV=sandbox

# Payment (Flutterwave) — optional for Phase 2
FLUTTERWAVE_KEY=FK_TEST_your_key
FLUTTERWAVE_SECRET=your_secret

# Environment
ENV=development
